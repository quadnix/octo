exports[`AwsDynamoDBServiceModule UT input changes should handle LocalSecondaryIndexes change should create table with LSI 1`] = `
"# service/main.tf
terraform {
  required_version = ">= 1.6.0"
  required_providers {
    aws = {
      source = "hashicorp/aws"
      version = ">= 5.49"
    }
  }
}

provider "aws" {
  alias = "_123-us-east-1"
  region = "us-east-1"
}

resource "aws_dynamodb_table" "dynamodb-test-table" {
  provider = aws._123-us-east-1
  attribute {
    name = "AccountId"
    type = "S"
  }
  attribute {
    name = "SortKey"
    type = "S"
  }
  attribute {
    name = "created"
    type = "N"
  }
  billing_mode = "PROVISIONED"
  deletion_protection_enabled = false
  hash_key = "AccountId"
  name = "test-table"
  table_class = "STANDARD"
  range_key = "SortKey"
  read_capacity = 5
  write_capacity = 5
  local_secondary_index {
    name = "LSI-created"
    projection_type = "ALL"
    range_key = "created"
  }
}

# service/outputs.tf
output "dynamodb-test-table-TableArn" {
  value = aws_dynamodb_table.dynamodb-test-table.arn
}

# service/terragrunt.hcl
remote_state {
  backend = "local"
  generate = {
    path      = "backend.tf"
    if_exists = "overwrite_terragrunt"
  }
  config = {
    path = "\${get_terragrunt_dir()}/terraform.tfstate"
  }
}

# service/variables.tf
<empty>"
`;

